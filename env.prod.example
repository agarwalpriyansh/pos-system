# ==============================================================================
# Production Environment Variables Template
# Copy this file to '.env' on your EC2 instance and fill in your values.
# ==============================================================================

# Database Settings (MongoDB Atlas)
MONGODB_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/your-db-name?retryWrites=true&w=majority

# Security Settings
JWT_SECRET=your_production_jwt_secret_key_here
GOOGLE_CLIENT_ID=your_google_oauth_client_id_here

# Redis Broker Settings
REDIS_PASSWORD=choose_a_strong_password_for_redis
REDIS_QUEUE_NAME=queue:bills
REDIS_DB=0

# Background Worker Settings
WORKER_COUNT=5

# WhatsApp Cloud API Settings
MOCK_WHATSAPP_API=true # Set to 'false' in production to send real messages
WHATSAPP_TOKEN=your_meta_whatsapp_token_here
WHATSAPP_PHONE_NUMBER_ID=your_whatsapp_phone_number_id_here
WHATSAPP_API_URL=https://graph.facebook.com/v25.0

# SMTP Email Configuration
MOCK_EMAIL_API=false # Set to 'false' to enable actual email sending
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_app_password_here
SMTP_FROM_EMAIL=no-reply@yourdomain.com
